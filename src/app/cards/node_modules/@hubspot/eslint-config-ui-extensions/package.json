{
  "name": "@hubspot/eslint-config-ui-extensions",
  "version": "1.1.1",
  "type": "module",
  "description": "eslint plugins for HubSpot React-based UI Extensions",
  "keywords": [
    "eslint",
    "eslintplugin",
    "eslint-plugin"
  ],
  "exports": "./dist/index.js",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "prettier": "@private/prettier-config",
  "dependencies": {
    "globals": "13.24.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@types/eslint": "9.6.1",
    "@types/estree-jsx": "1.0.5",
    "@types/node": "22.19.7",
    "@vitest/coverage-v8": "4.0.18",
    "@vitest/eslint-plugin": "1.6.6",
    "eslint": "9.39.2",
    "eslint-doc-generator": "2.3.0",
    "eslint-plugin-eslint-plugin": "5.5.1",
    "eslint-plugin-node": "11.1.0",
    "npm-run-all": "4.1.5",
    "prettier": "3.8.1",
    "typescript": "5.9.3",
    "typescript-eslint": "8.54.0",
    "vitest": "4.0.18",
    "@private/eslint-config": "1.0.0",
    "@private/prettier-config": "1.0.0"
  },
  "engines": {
    "node": "^16.0.0 || >= 18.0.0"
  },
  "peerDependencies": {
    "eslint": "^9"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "license": "MIT",
  "gitHead": "36d3a36ffaa5bde1a7b73dc139d75027aae65b7f",
  "scripts": {
    "build": "pnpm run clean && tsc",
    "clean": "rm -rf dist/",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore",
    "lint": "eslint lib/ && eslint-doc-generator --check",
    "lint:eslint-docs": "eslint-doc-generator --check",
    "lint:js": "eslint lib/",
    "lint:fix": "eslint lib/ --fix",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "update:eslint-docs": "eslint-doc-generator",
    "watch": "tsc --watch"
  }
}